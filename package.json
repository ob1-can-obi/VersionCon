{
  "name": "versioncon",
  "displayName": "VersionCon",
  "description": "Collaborative version control for teams with dependency-aware conflict detection",
  "version": "0.1.0",
  "publisher": "versioncon",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "versioncon",
          "title": "Team Sync",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "versioncon": [
        {
          "type": "webview",
          "id": "versioncon.sidebar",
          "name": "Session"
        },
        {
          "id": "versioncon.branchTree",
          "name": "Branch Files"
        },
        {
          "id": "versioncon.workspaceTree",
          "name": "My Workspace"
        },
        {
          "id": "versioncon.branchList",
          "name": "All Branches"
        },
        {
          "id": "versioncon.activityLog",
          "name": "Activity"
        },
        {
          "id": "versioncon.presence",
          "name": "Presence"
        }
      ]
    },
    "commands": [
      {
        "command": "versioncon.hostSession",
        "title": "VersionCon: Host Session"
      },
      {
        "command": "versioncon.joinSession",
        "title": "VersionCon: Join Session"
      },
      {
        "command": "versioncon.showSidebar",
        "title": "VersionCon: Show Sidebar"
      },
      {
        "command": "versioncon.addToWorkspace",
        "title": "Add to Workspace",
        "icon": "$(arrow-right)"
      },
      {
        "command": "versioncon.addFolderToWorkspace",
        "title": "Add Folder to Workspace",
        "icon": "$(arrow-right)"
      },
      {
        "command": "versioncon.stageForPush",
        "title": "Stage for Push",
        "icon": "$(arrow-left)"
      },
      {
        "command": "versioncon.unstageFile",
        "title": "Unstage",
        "icon": "$(close)"
      },
      {
        "command": "versioncon.push",
        "title": "Push to Branch",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "versioncon.previewDiff",
        "title": "Preview Diff",
        "icon": "$(diff)"
      },
      {
        "command": "versioncon.showPushHistory",
        "title": "Push History",
        "icon": "$(history)"
      },
      {
        "command": "versioncon.revertPush",
        "title": "Revert Push"
      },
      {
        "command": "versioncon.revertPushFiles",
        "title": "Revert Files from Push"
      },
      {
        "command": "versioncon.createBranch",
        "title": "VersionCon: Create Branch"
      },
      {
        "command": "versioncon.switchBranch",
        "title": "VersionCon: Switch Branch"
      },
      {
        "command": "versioncon.deleteBranch",
        "title": "VersionCon: Delete Branch"
      },
      {
        "command": "versioncon.mergeBranch",
        "title": "VersionCon: Merge Branch"
      },
      {
        "command": "versioncon.quickMergeFiles",
        "title": "VersionCon: Quick Merge Files Across Branches"
      },
      {
        "command": "versioncon.structuredMergeBranch",
        "title": "VersionCon: Merge Branch (Structured Walkthrough)"
      },
      {
        "command": "versioncon.manageBranchPermissions",
        "title": "VersionCon: Manage Branch Permissions"
      },
      {
        "command": "versioncon.sync",
        "title": "VersionCon: Sync"
      },
      {
        "command": "versioncon.previewBranchFile",
        "title": "Preview Branch File"
      },
      {
        "command": "versioncon.addNewFileToWorkspace",
        "title": "New File",
        "icon": "$(add)"
      },
      {
        "command": "versioncon.refreshBranchTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "versioncon.refreshWorkspaceTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "versioncon.refreshActivityLog",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "VersionCon"
      },
      {
        "command": "versioncon.activityLog.openEntry",
        "title": "Open Activity Entry",
        "category": "VersionCon"
      },
      {
        "command": "versioncon.refreshPresence",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "VersionCon"
      },
      {
        "command": "versioncon.openChat",
        "title": "Open Chat",
        "category": "VersionCon"
      },
      {
        "command": "versioncon.manageChat",
        "title": "Manage Chat",
        "icon": "$(gear)",
        "category": "VersionCon"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "versioncon.addToWorkspace",
          "when": "view == versioncon.branchTree && viewItem == branchFile",
          "group": "inline"
        },
        {
          "command": "versioncon.addFolderToWorkspace",
          "when": "view == versioncon.branchTree && viewItem == branchFolder",
          "group": "inline"
        },
        {
          "command": "versioncon.stageForPush",
          "when": "view == versioncon.workspaceTree && viewItem == workspaceFile",
          "group": "inline"
        },
        {
          "command": "versioncon.unstageFile",
          "when": "view == versioncon.workspaceTree && viewItem == workspaceFileStaged",
          "group": "inline"
        },
        {
          "command": "versioncon.previewDiff",
          "when": "view == versioncon.workspaceTree && viewItem == workspaceFileStaged",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "versioncon.refreshBranchTree",
          "when": "view == versioncon.branchTree",
          "group": "navigation"
        },
        {
          "command": "versioncon.push",
          "when": "view == versioncon.workspaceTree",
          "group": "navigation@1"
        },
        {
          "command": "versioncon.showPushHistory",
          "when": "view == versioncon.workspaceTree",
          "group": "navigation@2"
        },
        {
          "command": "versioncon.addNewFileToWorkspace",
          "when": "view == versioncon.workspaceTree",
          "group": "navigation@3"
        },
        {
          "command": "versioncon.refreshWorkspaceTree",
          "when": "view == versioncon.workspaceTree",
          "group": "navigation@4"
        },
        {
          "command": "versioncon.refreshActivityLog",
          "when": "view == versioncon.activityLog",
          "group": "navigation"
        },
        {
          "command": "versioncon.refreshPresence",
          "when": "view == versioncon.presence",
          "group": "navigation"
        },
        {
          "command": "versioncon.manageChat",
          "when": "view == versioncon.activityLog",
          "group": "navigation@2"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "versioncon.branchTree",
        "contents": "No branch files found.\nOpen a folder with a .versioncon/ directory to see branch files."
      },
      {
        "view": "versioncon.workspaceTree",
        "contents": "No files in workspace yet.\nClick the arrow (→) on a branch file to add it here.\nStage files with (←), then push with the upload button.\n\nTip: Drag this panel to the secondary sidebar for a split view."
      },
      {
        "view": "versioncon.activityLog",
        "contents": "Not connected.\nActivity from your team will appear here once you're in a session.\n[Host Session](command:versioncon.hostSession)\n[Join Session](command:versioncon.joinSession)",
        "when": "!versioncon.connected"
      },
      {
        "view": "versioncon.activityLog",
        "contents": "No activity yet.\nPushes, reverts, and new branches show up here as your team works.",
        "when": "versioncon.connected && versioncon.activityLog.empty"
      },
      {
        "view": "versioncon.presence",
        "contents": "Not connected.\nHost or join a session to see who's online.\n[Host Session](command:versioncon.hostSession)\n[Join Session](command:versioncon.joinSession)",
        "when": "!versioncon.connected"
      },
      {
        "view": "versioncon.presence",
        "contents": "You're the only one here.\nShare your session to invite teammates.",
        "when": "versioncon.connected && versioncon.presence.alone"
      }
    ],
    "configuration": {
      "title": "VersionCon",
      "properties": {
        "versioncon.displayName": {
          "type": "string",
          "default": "",
          "description": "Your display name shown to other team members in the chat, presence panel, and activity log. Set per-workspace by the host setup wizard; can be edited here at any time."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vscode-test",
    "lint": "tsc --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@vscode-elements/elements": "^2.5.1",
    "@vscode/codicons": "^0.0.40",
    "bonjour-service": "^1.3.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "nanoid": "^5.1.11",
    "web-tree-sitter": "^0.26.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  }
}
